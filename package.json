{
  "name": "bg-clean-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "cd apps/server && bun --hot server.ts",
    "start:server": "npm run start --workspace=server",
    "typecheck": "npm run typecheck --workspace=server"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  }
}
